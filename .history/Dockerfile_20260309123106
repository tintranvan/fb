FROM python:3.11-slim

WORKDIR /app

# Cài đặt dependencies cần thiết cho Playwright
RUN apt-get update && apt-get install -y \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libasound2 \
    && rm -rf /var/lib/apt/lists/*

# Copy files
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Cài Playwright browsers và dependencies
RUN playwright install chromium && playwright install-deps chromium

COPY scrape_bunchatv_streams.py .
COPY app.py .

# Expose port
EXPOSE 8080

# Run app
CMD ["python", "app.py"]

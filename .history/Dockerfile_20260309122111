FROM python:3.11-slim

WORKDIR /app

# Cài đặt dependencies
RUN apt-get update && apt-get install -y \
    chromium-browser \
    && rm -rf /var/lib/apt/lists/*

# Copy files
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY scrape_bunchatv_streams.py .
COPY app.py .

# Expose port
EXPOSE 8080

# Run app
CMD ["python", "app.py"]
